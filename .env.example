# 复制为 .env 后按需修改（docker compose 自动读取 .env）

# ---------- 构建加速（国内默认）----------
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# cn = 国内 apk/apt/npm；default = 上游默认源
MIRROR_PROFILE=cn

# DaoCloud 缓存的 Docker Hub library 镜像（避免直连 hub.docker.com）
DOCKER_HUB_MIRROR=docker.m.daocloud.io
NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
MAVEN_IMAGE=docker.m.daocloud.io/library/maven:3.9-eclipse-temurin-21
JRE_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:21-jre-alpine

MAVEN_SETTINGS_FILE=settings.xml
# 海外示例：MIRROR_PROFILE=default MAVEN_SETTINGS_FILE=settings-default.xml
#           NODE_IMAGE=node:18-alpine MAVEN_IMAGE=maven:3.9-eclipse-temurin-21 JRE_IMAGE=eclipse-temurin:21-jre-alpine

# ---------- 运行时 ----------
JWT_SECRET=change-me-in-production-256-bit-key
# HOST_MEDIA_PATH=E:\Movies
