# 复制为 .env 后按需修改（docker compose 自动读取 .env）

# ---------- 构建加速（国内默认）----------
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# cn = 国内 apk/apt/npm；default = 上游默认源
MIRROR_PROFILE=cn
# Alpine apk（ffmpeg 在 community，需完整 main+community 源）
# 可选：mirrors.ustc.edu.cn | mirrors.aliyun.com | mirrors.cloud.tencent.com
ALPINE_MIRROR_HOST=mirrors.tuna.tsinghua.edu.cn

# DaoCloud 缓存的 Docker Hub library 镜像（避免直连 hub.docker.com）
DOCKER_HUB_MIRROR=docker.m.daocloud.io
NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
MAVEN_IMAGE=docker.m.daocloud.io/library/maven:3.9-eclipse-temurin-21
JRE_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:21-jre-alpine

MAVEN_SETTINGS_FILE=settings.xml

# npm 包元数据（Docker 第 6 步 npm ci）。本机可测速后修改：
#   registry.npmjs.org（多数直连更快）
#   mirrors.huaweicloud.com/repository/npm/
#   registry.npmmirror.com（若你网络下反而慢，勿用）
NPM_REGISTRY=https://registry.npmjs.org

# 海外示例：MIRROR_PROFILE=default MAVEN_SETTINGS_FILE=settings-default.xml
#           NODE_IMAGE=node:18-alpine MAVEN_IMAGE=maven:3.9-eclipse-temurin-21 JRE_IMAGE=eclipse-temurin:21-jre-alpine

# ---------- 运行时 ----------
JWT_SECRET=change-me-in-production-256-bit-key
# 内嵌 PostgreSQL（单容器内运行，数据持久化到 ./data/postgres）
POSTGRES_DB=mediamanager
POSTGRES_USER=mediamanager
POSTGRES_PASSWORD=change-me-in-production
# 宿主机媒体目录（挂载到容器 /home/media）
HOST_MEDIA_PATH=E:\Movies
# 若数据库里仍是旧容器路径前缀（如 /home/test_media），保持默认即可（同目录双挂载）
# LEGACY_LIBRARY_MOUNT=/home/test_media
# 若 DB 存的是 Windows 绝对路径，用分号分隔映射，例如：
# MEDIAMANAGER_STORAGE_PATH_MAPPINGS=E:\Movies=/home/media

# ---------- JVM 配置 ----------
# JVM heap 参数，容器内默认 1G 最大堆。可按宿主机内存调整。
JAVA_OPTS=-Xmx1024m -Xms256m

# ---------- 功能开关 ----------
# 生产环境建议关闭 Swagger UI（nginx 已默认拦截 /swagger-ui 等路径）
SWAGGER_ENABLED=false

# ---------- AI（Docker 推荐；系统设置里勿填 localhost，容器内连不到宿主机 Ollama）----------
# MEDIAMANAGER_AI_DEFAULT_PROVIDER=ollama
# MEDIAMANAGER_AI_LLM_PROVIDER=ollama
# MEDIAMANAGER_AI_EMBED_PROVIDER=ollama
# MEDIAMANAGER_AI_OLLAMA_BASE_URL=http://host.docker.internal:11434
